// 自定义颜色配置
// 这个文件会覆盖主题默认的颜色设置

// 修复黑色区域问题
.cover
  background-color: transparent !important

.cover::before
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.8), rgba(123, 104, 238, 0.8)) !important

// 主色调
:root
  --color-primary: #4a90e2
  --color-secondary: #7b68ee
  --color-bg: #ffffff
  --color-bg-dark: #1a1a1a
  --color-text: #333333
  --color-text-dark: #e0e0e0
  --color-link: #4a90e2
  --color-link-hover: #357abd
  --color-code-bg: #f8f9fa
  --color-code-bg-dark: #2d3748
  --color-border: #e1e8ed
  --color-border-dark: #4a5568

// 修复页面背景
body
  background-color: #ffffff !important

.main
  background-color: transparent !important

// 修复友链页面样式
.links
  background-color: transparent !important
